<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>The Beer League 2026</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { display: ['Georgia', 'serif'] }
        }
      }
    }
  </script>
  <style>
    body { background-color: #0c0a09; color: #f5f5f4; font-family: system-ui, sans-serif; }
    .btn-primary { background:#f59e0b; color:#0c0a09; font-weight:700; padding:0.5rem 1rem; border-radius:0.5rem; border:none; cursor:pointer; transition:background 0.15s; }
    .btn-primary:hover { background:#fbbf24; }
    .btn-primary:disabled { opacity:0.5; cursor:not-allowed; }
    .btn-secondary { background:#292524; color:#e7e5e4; font-weight:600; padding:0.5rem 1rem; border-radius:0.5rem; border:1px solid #44403c; cursor:pointer; transition:background 0.15s; }
    .btn-secondary:hover { background:#3c3330; }
    .btn-danger { background:#7f1d1d; color:#fca5a5; font-weight:600; padding:0.5rem 1rem; border-radius:0.5rem; border:none; cursor:pointer; transition:background 0.15s; }
    .btn-danger:hover { background:#991b1b; }
    .card { background:#1c1917; border:1px solid #292524; border-radius:0.75rem; padding:1.25rem; }
    .input { background:#292524; border:1px solid #44403c; border-radius:0.5rem; padding:0.5rem 0.75rem; color:#f5f5f4; width:100%; outline:none; }
    .input:focus { border-color:#f59e0b; box-shadow:0 0 0 2px rgba(245,158,11,0.3); }
    .input::placeholder { color:#78716c; }
    .label { display:block; font-size:0.875rem; font-weight:500; color:#d6d3d1; margin-bottom:0.25rem; }
    .badge { display:inline-flex; align-items:center; padding:0.125rem 0.625rem; border-radius:9999px; font-size:0.75rem; font-weight:600; }
    .alert-success { background:#14532d22; border:1px solid #166534; color:#86efac; border-radius:0.5rem; padding:0.75rem 1rem; }
    .alert-error { background:#7f1d1d22; border:1px solid #991b1b; color:#fca5a5; border-radius:0.5rem; padding:0.75rem 1rem; }
  </style>
</head>
<body>
