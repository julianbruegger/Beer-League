<%- include('partials/head', { title: 'Special Powers' }) %>
<% const currentPage = '/powers'; %>
<%- include('partials/nav') %>

<div style="max-width:56rem; margin:0 auto; padding:1.5rem 1rem;">
  <h1 style="font-family:Georgia,serif; font-size:2rem; font-weight:700; color:#f59e0b; margin-bottom:0.5rem;">⚡ Special Powers</h1>
  <p style="color:#78716c; font-size:0.875rem; margin-bottom:1.5rem;">Earn powers by doing shoeys, shotgunning, or chugging — then unleash them on rivals.</p>

  <% if (success) { %>
    <div class="alert-success" style="margin-bottom:1rem;"><%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="alert-error" style="margin-bottom:1rem;"><%= error %></div>
  <% } %>

  <!-- Earn a Power -->
  <div class="card" style="margin-bottom:1.5rem;">
    <h2 style="font-size:1.125rem; font-weight:700; margin-bottom:1rem;">🏅 Earn a Power</h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:1rem;">
      <% Object.entries(powerLabels).forEach(([type, info]) => { %>
        <div style="background:#0c0a09; border-radius:0.5rem; padding:1rem; border:1px solid #292524;">
          <div style="font-size:1.5rem; margin-bottom:0.25rem;"><%= info.emoji %></div>
          <div style="font-weight:700; margin-bottom:0.25rem;"><%= info.label %></div>
          <div style="font-size:0.75rem; color:#78716c; margin-bottom:0.75rem;"><%= info.desc %></div>
          <% if (type === 'SHOTGUN') { %>
            <div style="font-size:0.7rem; color:#57534e; margin-bottom:0.5rem;">
              Your shotguns: <%= shotgunCount %> (next power at #<%= Math.ceil((shotgunCount + 1) / 3) * 3 %>)
            </div>
          <% } else if (type === 'CHUG') { %>
            <div style="font-size:0.7rem; color:#57534e; margin-bottom:0.5rem;">
              Your chugs: <%= chugCount %> (next power at #<%= Math.ceil((chugCount + 1) / 3) * 3 %>)
            </div>
          <% } else { %>
            <div style="font-size:0.7rem; color:#57534e; margin-bottom:0.5rem;">
              Total shoeys: <%= shoeyCount %>
            </div>
          <% } %>
          <form action="/powers/earn" method="POST">
            <input type="hidden" name="powerType" value="<%= type %>">
            <button type="submit" class="btn-secondary" style="font-size:0.8125rem; padding:0.375rem 0.75rem; width:100%;">
              Record <%= info.label %>
            </button>
          </form>
        </div>
      <% }) %>
    </div>
  </div>

  <!-- Unused Powers -->
  <div class="card" style="margin-bottom:1.5rem;">
    <h2 style="font-size:1.125rem; font-weight:700; margin-bottom:1rem;">
      🎯 Your Unused Powers (<%= unusedPowers.length %>)
    </h2>
    <% if (unusedPowers.length === 0) { %>
      <p style="color:#57534e; font-size:0.875rem;">No powers ready to use. Record a shoey, shotgun, or chug to earn one!</p>
    <% } else { %>
      <div style="display:flex; flex-direction:column; gap:0.75rem;">
        <% unusedPowers.forEach(power => { %>
          <div style="background:#0c0a09; border-radius:0.5rem; padding:1rem; border:1px solid #292524; display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap;">
            <div>
              <div style="font-weight:600;"><%= powerLabels[power.power_type]?.emoji %> <%= power.power_type %> Power</div>
              <div style="font-size:0.75rem; color:#78716c;">Deducts <span style="color:#f87171; font-weight:700;"><%= power.point_deduction %> pt<%= power.point_deduction > 1 ? 's' : '' %></span> from target</div>
              <div style="font-size:0.7rem; color:#57534e;">Earned <%= new Date(power.created_at).toLocaleDateString('en-GB') %></div>
            </div>
            <form action="/powers/use" method="POST" style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
              <input type="hidden" name="powerId" value="<%= power.id %>">
              <select name="targetId" class="input" style="width:auto; padding:0.375rem 0.5rem; font-size:0.8125rem;" required>
                <option value="">Pick target...</option>
                <% otherUsers.forEach(u => { %>
                  <option value="<%= u.id %>"><%= u.name %></option>
                <% }) %>
              </select>
              <button type="submit" class="btn-danger" style="font-size:0.8125rem; padding:0.375rem 0.75rem; white-space:nowrap;">
                Use Power 😈
              </button>
            </form>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
    <!-- Powers Used -->
    <div class="card">
      <h2 style="font-size:1rem; font-weight:700; margin-bottom:0.75rem;">Powers You Used</h2>
      <% if (usedPowers.length === 0) { %>
        <p style="color:#57534e; font-size:0.8125rem;">None yet.</p>
      <% } else { %>
        <div style="display:flex; flex-direction:column; gap:0.5rem;">
          <% usedPowers.forEach(p => { %>
            <div style="font-size:0.8125rem; padding:0.5rem; background:#0c0a09; border-radius:0.375rem;">
              <span style="color:#f87171;">-<%= p.point_deduction %>pt</span> on <strong><%= p.target_name %></strong>
              <div style="font-size:0.7rem; color:#57534e;"><%= p.power_type %> &middot; <%= new Date(p.used_at).toLocaleDateString('en-GB') %></div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Powers Against Me -->
    <div class="card">
      <h2 style="font-size:1rem; font-weight:700; margin-bottom:0.75rem;">Powers Used Against You</h2>
      <% if (powersUsedAgainstMe.length === 0) { %>
        <p style="color:#57534e; font-size:0.8125rem;">You've been spared so far. 😅</p>
      <% } else { %>
        <div style="display:flex; flex-direction:column; gap:0.5rem;">
          <% powersUsedAgainstMe.forEach(p => { %>
            <div style="font-size:0.8125rem; padding:0.5rem; background:#0c0a09; border-radius:0.375rem;">
              <span style="color:#f87171;">-<%= p.point_deduction %>pt</span> by <strong><%= p.earner_name %></strong>
              <div style="font-size:0.7rem; color:#57534e;"><%= p.power_type %> &middot; <%= new Date(p.used_at).toLocaleDateString('en-GB') %></div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/foot') %>
