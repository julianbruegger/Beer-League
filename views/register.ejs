<%- include('partials/head', { title: 'Register' }) %>
<div style="min-height:100vh; display:flex; align-items:center; justify-content:center; padding:1rem;">
  <div style="width:100%; max-width:28rem;">
    <div style="text-align:center; margin-bottom:2rem;">
      <div style="font-size:4rem; margin-bottom:1rem;">🍺</div>
      <h1 style="font-family:Georgia,serif; font-size:2.5rem; font-weight:700; color:#f59e0b; margin-bottom:0.5rem;">Join the League</h1>
      <p style="color:#78716c; font-size:0.875rem;">You need an invite code from a council member.</p>
    </div>

    <div class="card">
      <h2 style="font-size:1.25rem; font-weight:700; margin-bottom:1.5rem;">Create Account</h2>
      <form action="/register" method="POST" style="display:flex; flex-direction:column; gap:1rem;">
        <div>
          <label class="label">Your Name</label>
          <input type="text" name="name" class="input" placeholder='e.g. "The Foam Baron"' required>
        </div>
        <div>
          <label class="label">Email</label>
          <input type="email" name="email" class="input" placeholder="your@email.com" required>
        </div>
        <div>
          <label class="label">Password</label>
          <input type="password" name="password" class="input" placeholder="Min. 6 characters" required minlength="6">
        </div>
        <div>
          <label class="label">Invite Code</label>
          <input type="text" name="inviteCode" class="input" placeholder="Secret code from the council" required>
        </div>
        <% if (error) { %>
          <div class="alert-error"><%= error %></div>
        <% } %>
        <button type="submit" class="btn-primary" style="width:100%;">Join the League</button>
      </form>
      <p style="color:#78716c; font-size:0.875rem; margin-top:1rem; text-align:center;">
        Already a member? <a href="/login" style="color:#f59e0b; text-decoration:none;">Sign in</a>
      </p>
    </div>
  </div>
</div>
<%- include('partials/foot') %>
