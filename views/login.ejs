<%- include('partials/head', { title: 'Sign In' }) %>
<div style="min-height:100vh; display:flex; align-items:center; justify-content:center; padding:1rem;">
  <div style="width:100%; max-width:28rem;">
    <div style="text-align:center; margin-bottom:2rem;">
      <div style="font-size:4rem; margin-bottom:1rem;">🍺</div>
      <h1 style="font-family:Georgia,serif; font-size:2.5rem; font-weight:700; color:#f59e0b; margin-bottom:0.5rem;">The Beer League</h1>
      <p style="color:#78716c; font-size:0.875rem; font-style:italic;">"In heaven there is no beer, that's why we drink it here"</p>
      <p style="color:#57534e; font-size:0.75rem; margin-top:0.25rem;">— African uncle, 2023</p>
    </div>

    <% if (registered) { %>
      <div class="alert-success" style="margin-bottom:1rem;">Account created! Sign in below. 🎉</div>
    <% } %>

    <div class="card">
      <h2 style="font-size:1.25rem; font-weight:700; margin-bottom:1.5rem;">Sign In</h2>
      <form action="/login" method="POST" style="display:flex; flex-direction:column; gap:1rem;">
        <div>
          <label class="label">Email</label>
          <input type="email" name="email" class="input" placeholder="your@email.com" required>
        </div>
        <div>
          <label class="label">Password</label>
          <input type="password" name="password" class="input" placeholder="••••••••" required>
        </div>
        <% if (error) { %>
          <div class="alert-error"><%= error %></div>
        <% } %>
        <button type="submit" class="btn-primary" style="width:100%;">Sign In</button>
      </form>
      <p style="color:#78716c; font-size:0.875rem; margin-top:1rem; text-align:center;">
        New member? <a href="/register" style="color:#f59e0b; text-decoration:none;">Register with invite code</a>
      </p>
    </div>

    <div class="card" style="margin-top:1.5rem; font-size:0.75rem; color:#57534e;">
      <p style="color:#d6d3d1; font-weight:600; font-size:0.875rem; margin-bottom:0.5rem;">📜 The Annual Beer League</p>
      <p>League period: 11.05.2026 – 30.12.2026</p>
      <p>Final pub golf: 31.12.2026</p>
      <p style="margin-top:0.5rem; font-style:italic;">Commissioned by Beverage Beaver & The Guinness Guzzler</p>
    </div>
  </div>
</div>
<%- include('partials/foot') %>
